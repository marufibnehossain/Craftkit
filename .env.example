# =============================================================================
# ECOMMERCE TEMPLATE – Add your credentials when deploying
# =============================================================================

# Database (Prisma) – PostgreSQL connection string
# Leave empty to use mock products (storefront works, auth/admin need DB).
# Add your connection string + run migrations + seed for full app.
DATABASE_URL=""
DIRECT_URL=""

# NextAuth – required for auth
NEXTAUTH_URL="http://localhost:3000"
# Default for template testing; generate a unique one per project: openssl rand -base64 32
NEXTAUTH_SECRET="ecommerce-template-dev-secret-change-for-production"

# Site identity (used in layout, emails, receipt PDF)
NEXT_PUBLIC_SITE_NAME="Ecommerce"
NEXT_PUBLIC_SITE_TAGLINE="Your store, your way"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Branding (logo paths)
NEXT_PUBLIC_LOGO_URL="/images/logo-placeholder.svg"
NEXT_PUBLIC_LOGO_DARK_URL="/images/logo-placeholder.svg"
NEXT_PUBLIC_FAVICON="/images/logo-placeholder.svg"

# Contact (footer, legal pages, emails)
NEXT_PUBLIC_CONTACT_EMAIL=""
NEXT_PUBLIC_CONTACT_PHONE=""
NEXT_PUBLIC_CONTACT_ADDRESS=""
CONTACT_EMAIL=""

# Admin (seed) – set when running: npx prisma db seed
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# SMTP – optional; can also be configured in Admin → Email
# If both are set, Admin dashboard values take precedence
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_EMAIL=""

# Payment gateway – optional; configure in Admin → Payment
CCHEROES_TEST_MERCHANT_NAME=""
CCHEROES_TEST_MERCHANT_PASSWORD=""
CCHEROES_TEST_MODE="true"

# Supabase (optional – for client features)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
